{
  "name": "magnet-search",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && node --watch src/index.js",
    "dev:client": "cd client && npx vite --host",
    "build": "cd client && npx vite build",
    "start": "cd server && node src/index.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
